<view class="drawer-mask {{show?'show':''}}" bindtap="onClose"></view>
<view class="drawer {{show?'show':''}}" style="transform: translateY({{drawerY}}px);">
  <view class="drag-handle" bindtouchstart="touchStart" bindtouchmove="touchMove" bindtouchend="touchEnd">
    <view class="handle-bar"></view>
  </view>

  <!-- Header: always shows name + gender; clicking the name toggles the name section below -->
  <view class="profile-header">
    <view class="name-gender-row">
      <view class="name-edit-area">
        <!-- Collapsed: show display name only -->
        <view wx:if="{{!nameSectionExpanded && !creatingProfile}}" class="name-row">
          <view bindtap="onToggleNameSection" class="val-text name-large">
            {{displayName}}
          </view>
          <view class="header-icons" wx:if="{{showJumpBtn}}">
            <view class="icon-btn" bindtap="onJumpToTree" data-id="{{person.id}}">🌳</view>
          </view>
        </view>
      </view>

      <view class="gender-section" catchtap="onStartEditGender">
        <text wx:if="{{!editGender}}" class="gender-display-text {{person.gender || 'male'}}">{{person.gender == 'female' ? '女' : '男'}}</text>
        <radio-group wx:else bindchange="onUpdate" data-f="gender" class="gender-radio-group">
            <label class="gender-btn male {{person.gender=='male'?'active':''}}"><radio value="male" checked="{{person.gender=='male'}}"/>男</label>
            <label class="gender-btn female {{person.gender=='female'?'active':''}}"><radio value="female" checked="{{person.gender=='female'}}"/>女</label>
        </radio-group>
      </view>
    </view>
  </view>

  <!-- Expanded name section: surname / full name + alias / rank / hometown (click name or create to expand) -->
  <view wx:if="{{nameSectionExpanded || creatingProfile}}" class="name-section-expanded" catchtap="onExitEdit">
    <!-- 姓 -->
    <view class="profile-row-inline">
      <text class="row-label-inline">姓</text>
      <input class="val-text-inline surname-input {{activeField === 'surname' ? 'is-active' : ''}} {{changedFields.surname ? 'is-changed' : ''}}"
             value="{{person.surname}}" bindinput="onUpdateNameParts" bindfocus="onFocus" bindblur="onBlur"
             data-f="surname" placeholder="姓"
             placeholder-class="val-placeholder" catchtap="stop"
             focus="{{activeField === 'surname'}}" />
    </view>
    <!-- 名 -->
    <view class="profile-row-inline">
      <text class="row-label-inline">名</text>
      <input class="val-text-inline {{activeField === 'firstname' ? 'is-active' : ''}} {{changedFields.firstname ? 'is-changed' : ''}}"
             value="{{person.firstname}}" bindinput="onUpdateNameParts" bindfocus="onFocus" bindblur="onBlur"
             data-f="firstname" placeholder="名"
             placeholder-class="val-placeholder" catchtap="stop"
             focus="{{activeField === 'firstname'}}" />
    </view>
    <!-- 全名: gray if just surname+firstname concat -->
    <view class="profile-row-inline">
      <text class="row-label-inline">全名</text>
      <input class="val-text-inline {{nameManual ? 'is-manual' : ''}} {{!nameManual ? 'is-auto' : ''}} {{activeField === 'name' ? 'is-active' : ''}} {{changedFields.name ? 'is-changed' : ''}}"
             value="{{person.name}}" bindinput="onUpdateFullName" bindfocus="onFocus" bindblur="onBlur"
             data-f="name" placeholder="若不同于姓+名"
             placeholder-class="val-placeholder" catchtap="stop" />
    </view>

    <!-- Alias / Rank / Hometown -->
    <view class="profile-row-inline">
      <text class="row-label-inline">字号</text>
      <input class="val-text-inline {{activeField === 'alias' ? 'is-active' : ''}} {{changedFields.alias ? 'is-changed' : ''}}" 
             value="{{person.alias}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop"
             data-f="alias" placeholder="{{aliasHint}}" placeholder-class="val-placeholder"/>
      <view class="rank-section">
        <text class="row-label-inline">排行</text>
        <input class="val-text-inline rank-input {{activeField === 'rank' ? 'is-active' : ''}} {{changedFields.rank ? 'is-changed' : ''}}" 
               value="{{person.rank}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop"
               data-f="rank" placeholder="一" maxlength="2" placeholder-class="val-placeholder"/>
      </view>
    </view>
    <view class="profile-row-inline">
      <text class="row-label-inline">籍贯</text>
      <input class="val-text-inline {{activeField === 'hometown' ? 'is-active' : ''}} {{changedFields.hometown ? 'is-changed' : ''}}" 
             value="{{person.hometown}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop"
             data-f="hometown" placeholder="{{hometownHint || '江苏吴县'}}" placeholder-class="val-placeholder"/>
    </view>
  </view>

  <scroll-view scroll-y class="drawer-scroll" bindtap="onExitEdit">
    <!-- Life section: always-visible years + click label to reveal details -->
    <view class="life-grid">
      <view class="life-col" catchtap="stop">
        <view class="life-col-header" bindtap="onToggleLifeSection">
          <text class="life-col-title clickable">出生</text>
        </view>
        <view wx:if="{{lifeSectionExpanded}}" class="life-year-row">
            <input class="life-val {{activeField === 'bYear' ? 'is-active' : ''}} {{changedFields.bYear ? 'is-changed' : ''}}" value="{{person.bYear}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop" data-f="bYear" placeholder="公元纪年" placeholder-class="val-placeholder" type="number" />
          </view>
          <view wx:else class="life-year-row" bindtap="onToggleLifeSection">
            <text class="life-val-text {{changedFields.bYear ? 'is-changed' : ''}}">{{bYearDisplay || '公元纪年'}}</text>
          </view>
          <view wx:if="{{lifeSectionExpanded}}">
          <input class="life-val {{activeField === 'bDate' ? 'is-active' : ''}} {{changedFields.bDate ? 'is-changed' : ''}}" value="{{person.bDate}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop" data-f="bDate" placeholder="生辰" placeholder-class="val-placeholder" />
          <input class="life-val {{activeField === 'bPlace' ? 'is-active' : ''}} {{changedFields.bPlace ? 'is-changed' : ''}}" value="{{person.bPlace}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop" data-f="bPlace" placeholder="地点" placeholder-class="val-placeholder" />
          </view>
      </view>
      <view class="life-col" catchtap="stop">
        <view class="life-col-header" bindtap="onToggleLifeSection">
          <text class="life-col-title clickable">去世</text>
        </view>
        <view wx:if="{{lifeSectionExpanded}}" class="life-year-row">
            <input class="life-val {{activeField === 'dYear' ? 'is-active' : ''}} {{changedFields.dYear ? 'is-changed' : ''}}" value="{{person.dYear}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop" data-f="dYear" placeholder="公元纪年" placeholder-class="val-placeholder" type="number" />
          </view>
          <view wx:else class="life-year-row" bindtap="onToggleLifeSection">
            <text class="life-val-text {{changedFields.dYear ? 'is-changed' : ''}}">{{dYearDisplay || '公元纪年'}}</text>
          </view>
          <view wx:if="{{lifeSectionExpanded}}">
          <input class="life-val {{activeField === 'dDate' ? 'is-active' : ''}} {{changedFields.dDate ? 'is-changed' : ''}}" value="{{person.dDate}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop" data-f="dDate" placeholder="忌日" placeholder-class="val-placeholder" />
          <input class="life-val {{activeField === 'dPlace' ? 'is-active' : ''}} {{changedFields.dPlace ? 'is-changed' : ''}}" value="{{person.dPlace}}" bindinput="onUpdate" bindfocus="onFocus" bindblur="onBlur" catchtap="stop" data-f="dPlace" placeholder="地点" placeholder-class="val-placeholder" />
          </view>
      </view>
    </view>

    <!-- Relations section - hide for new person -->
    <view wx:if="{{!creatingProfile}}">

    <!-- Paternal Lineage Section (independent full-width section) -->
    <view wx:if="{{father}}" class="paternal-lineage-section">
      <!-- Great Grandfather (曾祖) -->
      <view wx:if="{{paternalAncestors.greatGrandfather}}" class="lineage-bar-row level-3">
        <text class="lineage-prefix-outside">曾祖</text>
        <view class="lineage-bar-content">
          <text class="lineage-bar-name">{{paternalAncestors.greatGrandfather}}</text>
          <text class="lineage-bar-year">{{paternalAncestors.greatGrandfatherYear || ''}}</text>
        </view>
      </view>
      <!-- Grandfather (祖) -->
      <view wx:if="{{paternalAncestors.grandfather}}" class="lineage-bar-row level-2">
        <text class="lineage-prefix-outside">祖</text>
        <view class="lineage-bar-content">
          <text class="lineage-bar-name">{{paternalAncestors.grandfather}}</text>
          <text class="lineage-bar-year">{{paternalAncestors.grandfatherYear || ''}}</text>
        </view>
      </view>
      <!-- Father (父) -->
      <view class="lineage-bar-row level-1">
        <text class="lineage-prefix-outside">父</text>
        <view class="lineage-bar-content">
          <text class="lineage-bar-name">{{paternalAncestors.father}}</text>
          <text class="lineage-bar-year">{{paternalAncestors.fatherYear || ''}}</text>
        </view>
      </view>
    </view>
    <!-- Add Father Button (only when person is a progenitor — no father deducible from ID) -->
    <button wx:if="{{!father && canAddFather}}" class="add-btn-tiny" style="width: 50%; margin: 0 auto;" bindtap="onAddFather">+ 父</button>

    <!-- Relations Grid -->
    <view class="rel-view-grid">
      <!-- Left column: Birth Mother and Spouses -->
      <view class="rel-view-col">
        <!-- Birth Mother -->
        <text class="row-label">生母</text>
        <picker wx:if="{{motherRange.length > 1}}" bindchange="onMotherChange" range="{{motherRange}}" range-key="label">
          <view wx:if="{{!person.motherId && !pendingMotherSelected}}" class="picker-box invitation">选生母</view>
          <view wx:else class="rel-card {{currentMotherGender}} {{pendingMotherSelected ? 'pending-highlight' : ''}}">
            <view class="name-scroll-container">
              <text class="rel-name-txt">{{currentMotherName}}</text>
            </view>
            <view class="item-right">
              <text class="rel-year-txt">{{currentMotherBYear}}</text>
            </view>
          </view>
        </picker>
        <!-- When no mother options, show placeholder text -->
        <view wx:else class="picker-box disabled">
          <text class="picker-disabled-text">无可选生母</text>
        </view>

        <!-- Spouses -->
        <text class="row-label">配偶</text>
        <view class="card-list">
          <view wx:for="{{localSpouses}}" wx:key="id" class="rel-card {{item.gender || 'unknown'}}">
            <view class="name-scroll-container" bindtap="onJumpToTree" data-id="{{item.id}}">
              <text class="rel-name-txt scrolling-text">{{item._displayName || '未命名'}}</text>
            </view>
            <view class="item-right">
              <text class="rel-year-txt">{{item.bYear || ''}}</text>
              <view wx:if="{{localSpouses.length > 1}}" class="reorder-handle" catchtouchstart="startReorder" catchtouchmove="moveReorder" catchtouchend="endReorder" data-type="spouses" data-index="{{index}}">⠿</view>
            </view>
          </view>
        </view>
        <button class="add-btn-tiny" bindtap="onAddSpouse">+ 配偶</button>
      </view>

      <!-- Right column: Children -->
      <view class="rel-view-col">
        <text class="row-label">子女</text>
        <view class="card-list">
          <view wx:for="{{localChildren}}" wx:key="id" class="rel-card {{item.gender || 'unknown'}}">
            <view class="name-scroll-container" bindtap="onJump" data-id="{{item.id}}">
              <text class="rel-name-txt scrolling-text">{{item.name || (item.surname ? item.surname + '氏' : '未命名')}}</text>
            </view>
            <view class="item-right">
              <text class="rel-year-txt">{{item.bYear || ''}}</text>
              <view wx:if="{{localChildren.length > 1}}" class="reorder-handle" catchtouchstart="startReorder" catchtouchmove="moveReorder" catchtouchend="endReorder" data-type="children" data-index="{{index}}">⠿</view>
            </view>
          </view>
        </view>
        <button wx:if="{{person.gender == 'male'}}" class="add-btn-tiny" bindtap="onAddChild">+ 子女</button>
      </view>
    </view>
    </view>

    <view class="action-footer" catchtap="stop">
      <!-- bindtap must be a static string; guard logic is inside onSave() -->
      <button class="save-btn-main {{hasChanges?'active':'disabled'}}" bindtap="onSave">保存</button>
      <view wx:if="{{canDelete && !creatingProfile}}" class="del-btn-archive" bindtap="onDelete">永久删除成员</view>
    </view>
  </scroll-view>
</view>