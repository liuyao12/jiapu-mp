view, text, input {
  color: #000;
  font-weight: normal;
  box-sizing: border-box;
  font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif;
}

/* Labels */
.row-label-inline, .life-col-title, .life-inline-label, .row-label { color: #000 !important; font-weight: normal !important; }
.row-label-inline { font-size: 22rpx; width: 52rpx; flex-shrink: 0; }
.row-label { font-size: 24rpx; display: block; margin-bottom: 10rpx; }
/* Same style for paternal lineage label */
.lineage-prefix-inline { color: #000 !important; font-weight: normal !important; font-size: 24rpx; }

/* Placeholders */
.val-placeholder { color: #999 !important; font-family: "STKaiti", "KaiTi", "AR PL UKai CN", serif !important; }
.full-name-placeholder { color: #999 !important; font-family: "SimSun", "Songti SC", "STSong", serif !important; font-weight: normal !important; }
.rel-year-txt,
.rel-year-inline { color: #888 !important; font-family: Consolas, monospace !important; font-size: 18rpx !important; flex-shrink: 0; }

/* Inline Inputs (Alias, Rank, Hometown) */
.profile-row-inline { display: flex; align-items: center; padding: 15rpx 0; border-bottom: 1rpx solid #f8f8f8; gap: 4rpx; }
.val-text-inline { flex: 1; font-size: 26rpx; font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif; font-weight: normal; height: 50rpx; padding: 0 10rpx; border-radius: 6rpx; border: 1rpx solid rgba(0,0,0,0.04); background: #f6f6f6; }
.rank-section { display: flex; align-items: center; width: 150rpx; border-left: 1rpx solid #eee; padding-left: 15rpx; margin-left: 10rpx; }
.rank-inline-label {
  width: auto;
  margin-left: 12rpx;
}
.rank-input {
  flex: 0 0 64rpx;
  width: 64rpx;
  min-width: 64rpx;
  max-width: 64rpx;
  text-align: center;
}

/* Collapsible sections */
.name-section-expanded {
  padding: 0 30rpx 20rpx;
  border-bottom: 0;
}
.name-xingming-row { gap: 6rpx; }
.name-xingming-row .surname-input {
  width: 80rpx;
  min-width: 80rpx;
  text-align: center;
  flex-shrink: 0;
}
.name-xingming-row .val-text-inline:not(.surname-input) {
  flex: 1;
  min-width: 0;
}
/* 全名: gray when auto-computed */
.is-auto { color: #999 !important; font-style: normal; background: #f6f6f6 !important; }

/* Life section: click label to reveal details */
.life-col-header {
  display: flex;
  align-items: center;
  gap: 6rpx;
  cursor: pointer;
}
.life-col-title.clickable { color: #000 !important; font-weight: normal !important; }
.life-expand-hint { font-size: 18rpx; color: #aaa; }
.life-year-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  cursor: pointer;
}
.life-year-row .life-val {
  width: auto;
  min-width: 80rpx;
}
.life-val-text {
  font-size: 24rpx;
  font-family: "SimSun", serif;
  height: 40rpx;
  line-height: 40rpx;
  color: #333;
  border: 1rpx solid transparent;
  border-radius: 4rpx;
  padding: 0 8rpx;
  white-space: nowrap;
}
.life-val-text.is-changed {
  background-color: transparent;
  border-color: #f57c00;
}

/* Highlight modified fields */
.is-changed {
  background-color: transparent !important;
  border: 2rpx solid #f57c00 !important;
}

/* Chinese era display */
.life-era {
  font-size: 22rpx;
  color: #888;
  font-family: "STKaiti", "KaiTi", serif;
  white-space: nowrap;
}

/* Header Name Editing */
.name-edit-container { display: flex; flex-direction: column; gap: 12rpx; width: 440rpx; }
.name-input-row { display: flex; flex-direction: row; align-items: center; gap: 10rpx; width: 100%; }
.name-row { display: flex; align-items: center; gap: 10rpx; flex: 1; }
.profile-read-section {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  min-width: 0;
}
.profile-hometown {
  color: #666 !important;
  font-size: 24rpx;
  line-height: 1.35;
  margin-bottom: 4rpx;
  font-family: "SimSun", serif;
}
.name-rank-suffix {
  font-size: 34rpx;
  color: #333 !important;
  margin-left: 8rpx;
}
.profile-alias {
  color: #333 !important;
  font-size: 28rpx;
  line-height: 1.35;
  margin-top: 4rpx;
  font-family: "STKaiti", "KaiTi", "FangSong", "STFangsong", "SimSun", serif;
}
.profile-summary {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8rpx 18rpx;
  margin-top: 8rpx;
  padding-bottom: 4rpx;
}
.profile-summary-item {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  max-width: 100%;
}
.profile-summary-label {
  color: #555 !important;
  font-size: 22rpx;
  flex-shrink: 0;
}
.profile-summary-value {
  color: #111 !important;
  font-size: 26rpx;
  font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.profile-summary-hometown {
  flex: 1 1 100%;
}
.profile-summary-hometown .profile-summary-value {
  white-space: normal;
  line-height: 1.35;
}
.name-editor-header { width: 100%; padding: 4rpx 0 2rpx 30rpx; box-sizing: border-box; }
.name-parts-row { display: flex; align-items: center; gap: 16rpx; width: 100%; max-width: 460rpx; }
.name-part-field {
  display: flex;
  align-items: center;
  gap: 4rpx;
  border-bottom: 0;
  min-width: 0;
}
.surname-part-field { flex: 0 0 164rpx; }
.firstname-part-field { flex: 0 1 246rpx; max-width: 246rpx; }
.name-part-label {
  font-size: 24rpx;
  color: #000;
  font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif;
  font-weight: normal;
  flex-shrink: 0;
}
.name-part-field .name-header-input {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  font-size: 42rpx;
  font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif !important;
  font-weight: normal !important;
  min-width: 0;
  opacity: 0.01;
  color: transparent !important;
}
.name-header-input-wrap {
  position: relative;
  height: 64rpx;
  line-height: 64rpx;
  border: 1rpx solid rgba(0,0,0,0.04);
  border-radius: 0;
  background: #f6f6f6;
  box-sizing: border-box;
  overflow: hidden;
}
.name-header-input-wrap.surname-wrap {
  width: 96rpx;
  min-width: 96rpx;
  max-width: 120rpx;
}
.name-header-input-wrap.firstname-wrap {
  flex: 1;
  min-width: 0;
}
.name-header-display {
  position: absolute;
  left: 4rpx;
  right: 4rpx;
  top: 0;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 42rpx;
  font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif !important;
  font-weight: normal !important;
  color: #000 !important;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  pointer-events: none;
}
.surname-display { text-align: center; }
.firstname-display { text-align: left; }
.header-icons { display: flex; gap: 8rpx; flex-shrink: 0; }
.name-input-box { border: 1rpx solid #eee; padding: 0 15rpx; height: 64rpx; font-size: 28rpx; border-radius: 8rpx; background: #fafafa; }

/* Surname input: one char by default, auto-expands when more chars entered */
.surname-input { 
  width: 70rpx; 
  min-width: 70rpx;
  max-width: 200rpx;
  flex-shrink: 0; 
  text-align: center; 
}

/* Firstname input: takes remaining space */
.firstname-input { 
  flex: 1; 
  min-width: 200rpx;
}
.name-input-box.full-name { font-size: 24rpx; height: 50rpx; color: #666; }
.name-input-box.is-auto { color: #999 !important; font-style: italic; background: #fdfdfd; }

/* Life Grid */
.life-grid { display: block; background: transparent; padding: 2rpx 0 18rpx 30rpx; margin-bottom: 10rpx; border-bottom: 1rpx solid #f8f8f8; }
.life-summary-row { display: flex; align-items: center; gap: 10rpx; flex-wrap: nowrap; }
.life-compact-row { display: flex; flex-direction: column; align-items: flex-start; justify-content: center; min-height: 58rpx; flex: 1 1 auto; min-width: 0; margin-left: -30rpx; padding: 4rpx 0; box-sizing: border-box; }
.life-compact-text {
  font-size: 24rpx;
  line-height: 30rpx;
  color: #222;
  font-family: "SimSun", "Songti SC", "STSong", serif;
  white-space: nowrap;
}
.life-compact-subtext {
  font-size: 21rpx;
  line-height: 28rpx;
  color: #777;
  font-family: "SimSun", "Songti SC", "STSong", serif;
  white-space: nowrap;
  padding-left: 8rpx;
}
.life-inline-item { display: flex; align-items: center; gap: 4rpx; min-width: 0; flex: 0 0 auto; }
.life-inline-label {
  font-size: 22rpx;
  line-height: 50rpx;
  color: #000 !important;
  font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif;
  width: 52rpx;
  flex-shrink: 0;
}
.age-inline-item { flex: 1 1 auto; gap: 0; }
.age-info-icon { width: 26rpx; height: 26rpx; line-height: 26rpx; border-radius: 50%; text-align: center; font-size: 18rpx; color: #777; border: 1rpx solid #bbb; font-family: serif; margin-left: 6rpx; flex-shrink: 0; }
.life-detail-row { display: flex; gap: 18rpx; margin-top: 12rpx; }
.life-detail-col { flex: 1; min-width: 0; }
.status-inline-item { margin-left: auto; }
.life-status-toggle {
  width: 78rpx !important;
  min-width: 78rpx !important;
  height: 42rpx !important;
  line-height: 40rpx !important;
  padding: 0 10rpx !important;
  margin: 0 !important;
  border: 1rpx solid rgba(0,0,0,0.14) !important;
  border-radius: 999rpx !important;
  background: #fff !important;
  color: #333 !important;
  font-size: 20rpx !important;
  font-family: "SimSun", "Songti SC", "STSong", serif !important;
  box-shadow: 0 2rpx 5rpx rgba(0,0,0,0.08);
}
.life-status-toggle::after { border: none !important; }
.life-event-add {
  width: 62rpx !important;
  min-width: 62rpx !important;
  height: 34rpx !important;
  line-height: 32rpx !important;
  padding: 0 !important;
  margin: 0 0 0 2rpx !important;
  border: 1rpx dashed #c9cfd6 !important;
  border-radius: 999rpx !important;
  background: #fff !important;
  color: #777 !important;
  font-size: 18rpx !important;
  font-family: "SimSun", "Songti SC", "STSong", serif !important;
  flex: 0 0 auto;
}
.life-event-add::after { border: none !important; }
.life-status-toggle.is-living {
  border-color: #8abbd9 !important;
  background: #e8f5fb !important;
  color: #075a83 !important;
}
.life-status-toggle.is-deceased {
  border-color: #b8b8b8 !important;
  background: #fff !important;
  color: #333 !important;
}
.life-status-toggle.is-disabled,
.life-status-toggle[disabled] {
  color: #aaa !important;
  border-color: rgba(0,0,0,0.06) !important;
  background: #f5f5f5 !important;
  opacity: 1 !important;
  box-shadow: none;
}
.life-val { font-size: 24rpx; font-family: "SimSun", serif; height: 40rpx; margin-bottom: 6rpx; border: 1rpx solid rgba(0,0,0,0.04); border-radius: 4rpx; padding: 0 8rpx; width: 100%; background: #f6f6f6; box-sizing: border-box; }
.life-year-field { width: 82rpx; min-width: 82rpx; text-align: center; padding: 0 6rpx; margin-bottom: 0; }
.life-year-chip { min-width: 82rpx; text-align: center; background: #f6f6f6; border-color: rgba(0,0,0,0.04); }
.life-age-input { text-align: center; padding: 0; flex: 0 0 56rpx; width: 56rpx; min-width: 56rpx; max-width: 56rpx; margin-bottom: 0; background: transparent !important; border-color: transparent !important; }
.life-age-input.is-active { background: transparent !important; border-color: rgba(0,0,0,0.12) !important; }
.age-year-row { display: flex; align-items: center; gap: 0; min-width: 0; }
.age-inline-item .life-val-text { padding: 0; border-color: transparent; }
.age-living-text { color: #666; }
.age-suffix { font-size: 22rpx; color: #555; flex-shrink: 0; }

/* Highlights */
.is-unsaved-text { color: #f57c00 !important; }
.is-unsaved-box { border: 3rpx solid #f57c00 !important; }
.is-active { border-color: rgba(0,0,0,0.18) !important; background: #f6f6f6 !important; }
.is-changed.is-active { border: 2rpx solid #f57c00 !important; background: #f6f6f6 !important; }
.life-age-input.is-auto-age,
.life-val.is-auto-life {
  background: #eeeeee !important;
  border-color: #eeeeee !important;
  color: #777 !important;
}

/* Drawer & Layout */
.drawer-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.4); z-index: 1000; visibility: hidden; opacity: 0; transition: 0.3s; }
.drawer-mask.show { visibility: visible; opacity: 1; }
.drawer { position: fixed; bottom: 0; left: 0; right: 0; height: 95vh; background: #fff; border-radius: 40rpx 40rpx 0 0; z-index: 1001; transition: transform 0.1s ease-out; padding: 0 40rpx 40rpx; box-shadow: 0 -10rpx 40rpx rgba(0,0,0,0.1); display: flex; flex-direction: column; }
.drawer.no-motion { transition: none !important; }
.drag-handle { width: 100%; height: 50rpx; display: flex; justify-content: center; align-items: center; flex-shrink: 0; position: relative; z-index: 2; background: #fff; }
.handle-bar { width: 80rpx; height: 8rpx; background: #ddd; border-radius: 4rpx; }
.drawer-scroll { flex: 1; height: 0; }

/* Header Info */
.profile-header { flex-shrink: 0; }
.name-gender-row { display: flex; align-items: center; justify-content: space-between; padding: 10rpx 0 20rpx; border-bottom: 0; }
.name-edit-area { flex: 1; min-width: 0; }
.gender-section { flex-shrink: 0; display: flex; align-items: center; justify-content: flex-end; min-width: 120rpx; }
.gender-radio-group { display: flex; align-items: center; gap: 8rpx; }
.name-large { font-size: 58rpx; line-height: 1.2; font-family: "Songti SC", "STSong", "Noto Serif CJK SC", "Source Han Serif SC", "SimSun", serif; min-height: 70rpx; }
.profile-name-edit-icon {
  width: 34rpx;
  height: 44rpx;
  line-height: 42rpx;
  text-align: center;
  color: #6f7882;
  border: none;
  background: transparent;
  font-size: 34rpx;
  flex: 0 0 auto;
  box-sizing: border-box;
}
.gender-display-text { font-size: 24rpx; padding: 6rpx 25rpx; border-radius: 40rpx; border: 1rpx solid #eee; font-family: "SimSun", "Songti SC", "STSong", serif; font-weight: normal; }
.gender-display-text.male { background: #bbdefb; color: #0d47a1 !important; }
.gender-display-text.female { background: #fce4ec; color: #880e4f !important; }
.gender-btn { font-size: 24rpx; padding: 10rpx 20rpx; border-radius: 30rpx; border: 1rpx solid #eee; margin-right: 10rpx; font-family: "SimSun", "Songti SC", "STSong", serif; font-weight: normal; }
.gender-btn.active.male { background: #bbdefb; color: #0d47a1 !important; border-color: rgba(0,0,0,0.05); }
.gender-btn.active.female { background: #fce4ec; color: #880e4f !important; border-color: rgba(0,0,0,0.05); }
.gender-btn radio { display: none; }

/* Relationships Grid */
.rel-view-grid { display: flex; flex-direction: row; gap: 20rpx; margin-top: 15rpx; padding-bottom: 150rpx; }
.rel-view-col { flex: 1; display: flex; flex-direction: column; min-width: 0; }
.birth-mother-picker { display: block; width: 100%; background: #fff !important; color: #000 !important; }
.rel-card { margin-bottom: 8rpx; padding: 0 14rpx; border-radius: 8rpx; display: flex !important; flex-direction: row !important; justify-content: space-between !important; align-items: center !important; border: 1rpx solid rgba(0,0,0,0.05); height: 52rpx; width: 100%; }
.rel-card.male { background: #bbdefb; border-color: rgba(0,0,0,0.05); }
.rel-card.female { background: #fce4ec; border-color: rgba(0,0,0,0.05); }
.rel-card.unknown { background: #dcedc8; border-color: rgba(0,0,0,0.05); }
.rel-card.pending-highlight { border: 2rpx solid #f57c00 !important; box-shadow: 0 0 0 2rpx rgba(245,124,0,0.25); }
.rel-card.tree-hidden { background: #eeeeee !important; border-color: #d7d7d7 !important; color: #888 !important; opacity: 0.78; }
.rel-card.tree-hidden .rel-name-txt,
.rel-card.tree-hidden .rel-rank-txt,
.rel-card.tree-hidden .rel-year-inline { color: #777 !important; }

.name-scroll-container { flex: 1; overflow: hidden; white-space: nowrap; display: flex; align-items: center; margin-right: 10rpx; }
.rel-label-scroll { display: flex; align-items: baseline; white-space: nowrap; min-width: 0; width: 100%; flex: 1 1 auto; overflow: hidden; }
.rel-name-txt { font-family: "SimSun", serif; font-size: 26rpx; color: #000; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; flex: 1 1 auto; }
.rel-card.relation-children .rel-name-txt { flex: 0 1 auto; }
.rel-card.relation-spouses .rel-name-txt { font-family: "KaiTi", "Kaiti SC", "STKaiti", "AR PL UKai CN", "FangSong", "STFangsong", "FangSong_GB2312", "Songti SC", "STSong", "SimSun", serif; font-style: normal; }
.rel-rank-txt { font-family: "SimSun", serif; font-size: 18rpx; color: #000; opacity: 0.72; flex-shrink: 0; }
.rel-card.relation-spouses .rel-rank-txt { font-family: "KaiTi", "Kaiti SC", "STKaiti", "AR PL UKai CN", "FangSong", "STFangsong", "FangSong_GB2312", "Songti SC", "STSong", "SimSun", serif; font-style: normal; }
.rel-year-inline { margin-left: auto; padding-left: 8rpx; flex: 0 0 auto; text-align: right; }
.item-right { display: flex; align-items: center; gap: 8rpx; flex-shrink: 0; background: inherit; height: 100%; padding-left: 10rpx; }

/* Marquee Animation */
.scrolling-text { animation: marquee 10s linear infinite; animation-play-state: paused; }
.rel-card:active .scrolling-text { animation-play-state: running; }
@keyframes marquee { 0% { transform: translateX(0); } 20% { transform: translateX(0); } 100% { transform: translateX(-100%); } }

/* Footer */
.reorder-grip {
  width: 34rpx;
  height: 44rpx;
  line-height: 44rpx;
  text-align: center;
  color: rgba(69,90,100,0.55);
  font-size: 24rpx;
  flex-shrink: 0;
}
.rel-card.dragging {
  opacity: 0.86;
  transform: scale(1.02);
  box-shadow: 0 8rpx 22rpx rgba(0,0,0,0.16);
  position: relative;
  z-index: 3;
}
.header-icons {
  display: flex;
  gap: 10rpx;
  margin-left: 0;
  padding-left: 36rpx;
  align-items: center;
  flex-shrink: 0;
}
.icon-btn {
  font-size: 34rpx;
  line-height: 42rpx;
  opacity: 0.76;
  padding: 0 4rpx;
  flex-shrink: 0;
}
.header-tree-icon {
  width: 54rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 2rpx;
  padding: 0;
  opacity: 1;
  overflow: visible;
}
.profile-lineage-icon {
  position: relative;
  display: block;
  width: 48rpx;
  height: 40rpx;
}
.profile-lineage-connector,
.profile-lineage-bar {
  position: absolute;
  display: block;
}
.profile-lineage-connector,
.profile-lineage-bar {
  background: #6f7882;
  border-radius: 999rpx;
}
.profile-lineage-connector {
  z-index: 2;
}
.profile-lineage-connector.vertical {
  left: 12rpx;
  top: 7rpx;
  width: 3rpx;
  height: 26rpx;
}
.profile-lineage-connector.middle,
.profile-lineage-connector.lower {
  left: 12rpx;
  width: 14rpx;
  height: 3rpx;
  z-index: 4;
}
.profile-lineage-connector.middle { top: 18rpx; }
.profile-lineage-connector.lower { top: 30rpx; }
.profile-lineage-bar {
  height: 7rpx;
  z-index: 3;
}
.profile-lineage-bar.first,
.profile-lineage-bar.middle,
.profile-lineage-bar.lower {
  width: 32rpx;
}
.profile-lineage-bar.first {
  left: 7rpx;
  top: 4rpx;
}
.profile-lineage-bar.middle,
.profile-lineage-bar.lower {
  left: 20rpx;
}
.profile-lineage-bar.middle { top: 16rpx; }
.profile-lineage-bar.lower { top: 28rpx; }
.add-btn-tiny {
  width: 100%;
  font-size: 18rpx;
  background: #fff;
  border: 1rpx dashed #ccc;
  color: #999;
  height: 48rpx;
  line-height: 48rpx;
  margin-top: 5rpx;
  padding: 0 !important;
  box-sizing: border-box;
  max-width: 100%;
}
.relation-hint {
  min-height: 48rpx;
  line-height: 32rpx;
  margin-top: 5rpx;
  padding: 8rpx 12rpx;
  border: 1rpx dashed #d5d8dc;
  border-radius: 8rpx;
  background: #fafafa;
  color: #777;
  font-size: 21rpx;
  font-family: "SimSun", "Songti SC", "STSong", serif;
  text-align: center;
