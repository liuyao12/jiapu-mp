/* pages/tree/tree.wxss */
.app-container { height: 100vh; display: flex; flex-direction: column; background: #f0f2f5; font-family: "SimSun", serif; overflow: hidden; }
text, view, button, input { font-weight: normal !important; }

/* ── Topbar ── */
.topbar { background: #fff; border-bottom: 1rpx solid #ddd; z-index: 200; flex-shrink: 0; padding: 12rpx 24rpx 8rpx; }

/* Shared row */
.bar-row { display: flex; align-items: center; }

/* Row 1: title */
.title-row { justify-content: space-between; margin-bottom: 4rpx; }
.title-left { display: flex; align-items: center; min-width: 120rpx; }
.title-center { display: flex; align-items: center; justify-content: center; flex: 1; }
.title-right { display: flex; gap: 8rpx; align-items: center; min-width: 60rpx; justify-content: flex-end; }
.family-title { font-size: 28rpx; color: #333; font-weight: 500; }
.stats { font-size: 16rpx; color: #999; }
.action-btn { background: #f5f5f5 !important; color: #666 !important; font-size: 20rpx !important; padding: 0 16rpx !important; height: 48rpx; line-height: 48rpx; }
.icon-btn { background: #f5f5f5 !important; color: #666 !important; font-size: 26rpx !important; padding: 0 10rpx !important; height: 48rpx; line-height: 48rpx; min-width: 48rpx; }
.icon-btn.active { background: #e3f2fd !important; color: #0277bd !important; }

/* Fit-width button: horizontal double arrow ↔ */
.fit-width-btn {
  padding: 0 12rpx !important;
  min-width: 48rpx;
  font-size: 28rpx !important;
}
.back-btn { background: #fff3e0 !important; color: #e65100 !important; font-size: 20rpx !important; padding: 0 16rpx !important; height: 48rpx; line-height: 48rpx; }
.new-btn { background: #e3f2fd !important; color: #0277bd !important; font-size: 20rpx !important; padding: 0 16rpx !important; height: 48rpx; line-height: 48rpx; }
.btn-spacer { flex: 1; }
.btn-group { display: flex; gap: 8rpx; align-items: center; }

/* Row 2: toggles */
.toggle-row { gap: 8rpx; justify-content: flex-start; padding-left: 0; }
.toggle-left { display: flex; align-items: center; min-width: 120rpx; }
.toggle-center { display: flex; align-items: center; gap: 16rpx; flex: 1; justify-content: center; }
.toggle-right { display: flex; align-items: center; min-width: 120rpx; }
.toggle-label { font-size: 20rpx; color: #999; margin-right: 4rpx; }
.toggle-item { display: flex; align-items: center; margin-right: 8rpx; }
.toggle-text  { font-size: 22rpx; color: #555; margin-left: -4rpx; white-space: nowrap; }
.toggle-spacer { flex: 1; }

/* Row 2: action buttons */
.btn-row { gap: 12rpx; margin-bottom: 6rpx; }
.tb-btn { margin: 0 !important; padding: 0 12rpx !important; height: 48rpx; line-height: 48rpx; font-size: 20rpx; border-radius: 6rpx !important; border: none !important; display: flex; align-items: center; justify-content: center; }
.import-btn, .export-btn { width: 100rpx; background: #e3f2fd !important; color: #0277bd !important; }
.export-btn { background: #e8f5e9 !important; color: #2e7d32 !important; }
.reset-btn { background: #f0f0f0 !important; color: #333 !important; padding: 0 8rpx !important; font-size: 20rpx; }

/* Toggles */
.toggle-label { font-size: 20rpx; color: #999; margin-right: 4rpx; }
.toggle-item { display: flex; align-items: center; margin-right: 4rpx; }
.toggle-text  { font-size: 22rpx; color: #555; margin-left: -4rpx; white-space: nowrap; }

/* ── Empty state ── */
/* ── Empty state ── */
.empty-state {
  flex: 1;
  height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-tip { font-size: 34rpx; color: #333; font-weight: bold; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #888; margin-bottom: 48rpx; }
.add-ancestor-btn {
  background: #1565c0 !important;
  color: #fff !important;
  font-size: 32rpx !important;
  padding: 0 60rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx !important;
  border: none !important;
  box-shadow: 0 6rpx 24rpx rgba(21,101,192,0.35);
}

/* ── Tree area ── */
.tree-area-outer {
  flex: 1;
  height: 0;
  background: #fff;
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.tree-area-body {
  flex: 1;
  height: 0;
  width: 100%;
  overflow: auto;
  position: relative;
  min-height: 200rpx;
}

.canvas-wrapper {
  width: 100%;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  position: relative;
}

/* 标尺容器 - 使用 sticky 定位固定在 canvas 顶部 */
.ruler-container {
  position: sticky;
  top: 0;
  height: 64rpx;
  width: 100%;
  border-bottom: 0;
  background: #fff;
  z-index: 150;
  flex-shrink: 0;
  overflow: visible;
}

/* Opaque background covering entire horizontal scroll range */
.ruler-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: -9999rpx;
  right: -9999rpx;
  bottom: 0;
  background: #fff;
  z-index: -1;
}

/* 标尺底部的水平线（贯穿整个标尺长度） */
.ruler-container::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: -9999rpx;
  right: -9999rpx;
  height: 2rpx;
  background: #bbb;
  z-index: 1;
}

/* 外部2026年线（在画布内，随缩放变化，仅时间轴视图显示） */
.current-year-line-outer {
  position: absolute;
  top: 64rpx; /* 从标尺下方开始 */
  width: 3rpx;
  background: linear-gradient(180deg, rgba(230,81,0,0.8) 0%, rgba(230,81,0,0.3) 100%);
  z-index: 5;
  pointer-events: none;
  height: 100vh;
  box-shadow: 0 0 8rpx rgba(230,81,0,0.3);
}

.current-year-label {
  position: absolute;
  top: 4rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: #e65100;
  font-family: Consolas;
  white-space: nowrap;
  z-index: 160; /* 高于标尺的z-index:150 */
  font-weight: bold;
}

.canvas {
  transform-origin: 0 0;
  flex-shrink: 0;
  margin-left: 0;
  position: relative;
  min-height: 100rpx;
}

/* 标尺刻度线样式 */
.tick {
  position: absolute;
  bottom: 2rpx; /* 在标尺底部水平线之上 */
  height: 8rpx; /* 短刻度线 */
  width: 1rpx;
  background: rgba(0,0,0,0.3);
  z-index: 10;
}

/* 中等刻度（每20年） */
.tick.type-medium {
  height: 12rpx;
  width: 2rpx;
}

/* 大刻度（每100年） */
.tick.type-major {
  height: 24rpx; /* 更高的刻度 */
  width: 4rpx; /* 更粗的刻度 */
  background: rgba(0,0,0,0.8);
}

/* 当前年刻度 */
.tick.current-year {
  height: 20rpx;
  width: 4rpx;
  background: #e65100;
}

.tick-label {
  position: absolute;
  bottom: 14rpx; /* 标签在刻度线上方，考虑水平线高度 */
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: #000;
  font-family: Consolas;
  white-space: nowrap;
  z-index: 10;
}

.tick.current-year .tick-label,
.current-year-label {
  color: #e65100;
  font-weight: bold;
}

/* 标准视图：代际块 */
.gen-block {
  position: absolute;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 1rpx solid #ccc;  /* 垂直线在块左边界（x=40,120,200...） */
  z-index: 5;
}
.gen-block-label {
  color: #888;
  font-family: Consolas, monospace;
  white-space: nowrap;
}

/* Current year line - full height vertical line，从标尺顶部延伸到屏幕底部（不受maxH限制） */
.current-year-line { position: absolute; top: 0; height: 10000rpx; width: 2rpx; background: #e65100; z-index: 5; opacity: 0.6; }
/* 2026年线标签 - 标尺的一部分，在竖线右侧 */
.current-year-label {
  position: absolute;
  top: 4rpx;
  left: 4rpx;
  font-size: 22rpx;
  color: #e65100;
  font-weight: bold;
  white-space: nowrap;
  background: rgba(255,255,255,0.95);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  box-shadow: 0 2rpx 8rpx rgba(230,81,0,0.2);
  border: 1rpx solid rgba(230,81,0,0.3);
  pointer-events: none;
  z-index: 4;
}
.tree-content {
  position: relative;
  padding-top: 80rpx;
  padding-bottom: 500rpx;
}

/* ── Nodes ── */
.node { position: absolute; top: 0; left: 0; height: 72rpx !important; display: flex; align-items: stretch; z-index: 10; box-sizing: border-box; overflow: visible; min-height: 0 !important; max-height: 72rpx !important; padding: 0 !important; margin: 0 !important; }
.node-inner { display: flex; align-items: center; background: #fff; border: 1rpx solid rgba(0,0,0,0.12); border-radius: 0 4rpx 4rpx 0; padding: 0 10rpx; width: 100%; height: 72rpx !important; box-sizing: border-box; line-height: 1.2; min-height: 0 !important; overflow: visible; }
.male   .node-inner { background: #bbdefb !important; }
.female .node-inner { background: #fce4ec !important; }
.unknown .node-inner { background: #dcedc8 !important; }

.p-name { font-size: 28rpx; margin-right: 10rpx; color: #000; white-space: nowrap; font-family: "SimSun", serif; line-height: 1.2; }
.spouse .p-name { font-family: "STKaiti", "KaiTi", "AR PL UKai CN", serif; }
.p-life { font-size: 20rpx; color: #666; font-family: Consolas, monospace; white-space: nowrap; line-height: 1.2; }

.icon-box { width: 44rpx; height: 44rpx; display: flex; align-items: center; justify-content: center; margin-right: 8rpx; flex-shrink: 0; overflow: hidden; }
.circle-icon { width: 24rpx; height: 24rpx; border: 1.5rpx solid #555; border-radius: 50%; position: relative; background: transparent !important; box-sizing: border-box; }
.line-h { position: absolute; top: 11rpx; left: 5rpx; width: 14rpx; height: 1.5rpx; background: #555; box-sizing: border-box; }
.line-v { position: absolute; top: 5rpx; left: 11rpx; width: 1.5rpx; height: 14rpx; background: #555; box-sizing: border-box; }
.spouse-icon { font-size: 34rpx; color: #555; opacity: 0.8; }

/* Jump button for outsiders */
.jump-btn {
  display: inline-block;
  margin-left: 8rpx;
  font-size: 24rpx;
  color: #1976d2;
  padding: 4rpx 8rpx;
  background: rgba(25, 118, 210, 0.1);
  border-radius: 4rpx;
  flex-shrink: 0;
}

/* ── Lines ── */
.line { position: absolute; background: #ccc; z-index: 5; pointer-events: none; }
.line.stem   { width: 1.5rpx; }
.line.branch { height: 1.5rpx; }
.line.marriage { width: 1.5rpx; background: #ff9800; }

/* ── Progenitor List Modal ── */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progenitor-modal {
  width: 80%;
  max-width: 600rpx;
  max-height: 80%;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.modal-header {
  padding: 32rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #e0e0e0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.modal-close {
  background: none;
  border: none;
  font-size: 32rpx;
  color: #999;
  padding: 0;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.progenitor-list {
  flex: 1;
  max-height: 600rpx;
}

.empty-list {
  padding: 80rpx 32rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.progenitor-item {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: background-color 0.2s;
}

.progenitor-item:active {
  background-color: #f5f5f5;
}

.progenitor-info {
  flex: 1;
}

.progenitor-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  display: block;
  margin-bottom: 8rpx;
}

.progenitor-details {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.progenitor-year {
  font-size: 22rpx;
  color: #666;
}

.progenitor-stats {
  font-size: 22rpx;
  color: #999;
}

.progenitor-action {
  font-size: 28rpx;
  color: #1976d2;
  margin-left: 16rpx;
}

.catchTap {
  /* Prevent event bubbling */
}

/* ── Vertical Button Stack ── */
.vertical-buttons {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

/* ── Family Title Dropdown ── */
.family-title-dropdown {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  transition: background-color 0.2s;
}

.family-title-dropdown:active {
  background-color: #e0e0e0;
}

.dropdown-arrow {
  font-size: 20rpx;
  color: #666;
  transition: transform 0.2s;
}

/* ── Progenitor Dropdown Menu ── */
.dropdown-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 900;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding-top: 120rpx;
}

.dropdown-content {
  width: 80%;
  max-width: 600rpx;
  max-height: 70%;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
}

.dropdown-header {
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #e0e0e0;
  background: #f8f9fa;
}

.dropdown-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  text-align: center;
  display: block;
}

.dropdown-list {
  flex: 1;
  max-height: 600rpx;
}

/* Workspace separator - darker line between different workspaces (vs lighter #f0f0f0 within) */
.workspace-separator {
  width: 100%;
  margin: 4rpx 0;
  height: 1rpx;
  background: #ccc;
}

.empty-workspace {
  padding: 40rpx 32rpx;
  text-align: center;
  color: #999;
  font-size: 24rpx;
  font-style: italic;
}

.empty-dropdown {
  padding: 60rpx 32rpx;
  text-align: center;
  color: #999;
  font-size: 26rpx;
}

.dropdown-item {
  padding: 20rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
  transition: background-color 0.2s;
}

.dropdown-item:active {
  background-color: #f5f5f5;
}

.new-tree-item {
  border-bottom: none !important;
}

.last-in-workspace {
  border-bottom: none !important;
}

.dropdown-item-text {
  font-size: 28rpx;
  color: #333;
}

.new-tree-item .dropdown-item-text {
  color: #333;
}

.progenitor-dropdown-info {
  flex: 1;
}

/* Row: name on left, stats on right — same line */
.progenitor-dropdown-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.progenitor-dropdown-name {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  flex: 0 0 auto;
  margin-right: 8rpx;
}

.progenitor-dropdown-year-inline {
  font-size: 20rpx;
  color: #666;
  flex: 0 0 auto;
  margin-right: 12rpx;
}

.progenitor-dropdown-details {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.progenitor-dropdown-year {
  font-size: 20rpx;
  color: #666;
}

.progenitor-dropdown-stats {
  font-size: 20rpx;
  color: #999;
}

/* ── Statistics Icons ── */
.progenitor-stats-icons {
  display: flex;
  align-items: center;
  gap: 8rpx;
  flex-shrink: 0;
}

.stat-icon {
  font-size: 20rpx;
  padding: 2rpx 6rpx;
  border-radius: 4rpx;
  display: flex;
  align-items: center;
  gap: 2rpx;
}

.stat-icon.male {
  color: #1976d2;
  background: rgba(25, 118, 210, 0.1);
}

.stat-icon.female {
  color: #c2185b;
  background: rgba(194, 24, 91, 0.1);
}

.stat-icon.marriage {
  color: #f57c00;
  background: rgba(245, 124, 0, 0.1);
}