<!-- pages/tree/tree.wxml -->
<view class="app-container">
  <view class="topbar">

    <!-- Row 1: Import on left, Title in center -->
    <view class="bar-row title-row">
      <view class="title-left">
        <button class="tb-btn action-btn" size="mini" bindtap="onImport">📥 导入</button>
      </view>
      <view class="title-center">
        <view class="family-title-dropdown" bindtap="toggleProgenitorDropdown">
          <text class="family-title">{{familyName}}</text>
          <text class="dropdown-arrow">▼</text>
        </view>
      </view>
      <view class="title-right">
        <button class="tb-btn icon-btn fit-width-btn {{viewScale < 1 ? 'active' : ''}}" size="mini" bindtap="toggleFitWidth" title="适应宽度">↔</button>
      </view>
    </view>

    <!-- Row 2: Share on left, Toggles in center -->
    <view class="bar-row toggle-row">
      <view class="toggle-left">
        <button class="tb-btn action-btn" size="mini" bindtap="shareGenealogy">📤 分享</button>
      </view>
      <view class="toggle-center">
        <label class="toggle-item">
          <switch checked="{{showSpouses}}"  bindchange="toggleSpouses"  color="#0277bd" style="transform:scale(0.6);"/>
          <text class="toggle-text">配偶</text>
        </label>
        <label class="toggle-item">
          <switch checked="{{showMaternal}}" bindchange="toggleMaternal" color="#0277bd" style="transform:scale(0.6);"/>
          <text class="toggle-text">外甥</text>
        </label>
        <label class="toggle-item">
          <switch checked="{{showTimeline}}" bindchange="toggleTimeline" color="#0277bd" style="transform:scale(0.6);"/>
          <text class="toggle-text">时间轴</text>
        </label>
      </view>
      <view class="toggle-right">
      </view>
    </view>

  </view>

  <!-- Empty tree state: show a prominent add-ancestor button -->
  <view wx:if="{{!db.activeRootId || nodes.length === 0}}" class="empty-state">
    <view class="empty-icon">🌳</view>
    <text class="empty-tip">家谱空空如也</text>
    <text class="empty-sub">点击下方按钮，添加第一位始祖</text>
    <button class="add-ancestor-btn" bindtap="onAddAncestorBtnTap">＋ 添加始祖</button>
  </view>

  <view wx:else class="tree-area-outer">
    <!-- 主内容区域 -->
    <scroll-view id="mainScroll" class="tree-area-body" scroll-x="{{!lockHorizontalScroll}}" scroll-y="{{true}}" scroll-left="{{mainScrollLeft}}" scroll-top="{{mainScrollTop}}" bindscroll="onMainScroll">
      <view class="canvas-wrapper">
        <!-- 标尺（时间轴视图：年份标尺；标准视图：代际块） -->
        <view class="ruler-container" style="margin-left:{{fitWidthOffset}}rpx;">
          <!-- 标准视图：代际块 -->
          <view wx:if="{{!showTimeline}}">
            <!-- 每个块：左边界在垂直线位置（x=40,120,200...对齐节点左缘），块宽80，内容居中 -->
            <view wx:for="{{rulerTicks}}" wx:key="x" class="gen-block" style="left:{{(item.x || 40) * viewScale}}rpx; width:{{80 * viewScale}}rpx;">
              <text wx:if="{{item.label}}" class="gen-block-label" style="font-size:{{20 * viewScale}}rpx;">{{item.label}}</text>
            </view>
          </view>
          <!-- 时间轴视图：年份刻度 -->
          <view wx:if="{{showTimeline}}">
            <view wx:for="{{rulerTicks}}" wx:key="x" class="tick {{item.isCurrentYear?'current-year':''}}" style="left:{{((item.x || 0) + 40) * viewScale}}rpx">
              <text wx:if="{{item.label}}" class="tick-label" style="font-size:{{24 * viewScale}}rpx">{{item.label}}</text>
            </view>
          </view>
          <!-- 2026年线（从标尺顶部开始，延伸到屏幕底部） -->
          <view wx:if="{{showTimeline && currentYearLineX >= 0}}" class="current-year-line" style="left:{{((currentYearLineX || 0) + 40) * viewScale}}rpx;"></view>
          <!-- 2026年标签 - 在竖线右侧 -->
          <text wx:if="{{showTimeline && currentYearLineX >= 0}}" class="current-year-label" style="left:{{((currentYearLineX || 0) + 94) * viewScale}}rpx; font-size:{{22 * viewScale}}rpx; padding:{{4 * viewScale}}rpx {{10 * viewScale}}rpx; border-radius:{{6 * viewScale}}rpx; box-shadow:0 {{2 * viewScale}}rpx {{8 * viewScale}}rpx rgba(230,81,0,0.2);">{{currentYear || 2026}}年</text>
        </view>

        <!-- Canvas内容（可缩放） -->
        <view class="canvas" style="width:{{maxR}}rpx; height:{{maxH}}rpx; transform: scale({{viewScale}}); transform-origin: 0 0; margin-left:{{fitWidthOffset}}rpx;">
          <view class="tree-content">
        <view wx:for="{{lines}}" wx:key="index" class="line {{item.type || 'stem'}}" style="left:{{(item.x || 0) + 40}}rpx; top:{{item.y || 0}}rpx; width:{{item.w || 1.5}}rpx; height:{{item.h || 1.5}}rpx;"></view>
        <view wx:for="{{nodes}}" wx:key="id" class="node {{item.gender || 'unknown'}} {{item.isSpouse?'spouse':''}}" style="left:{{(item.x || 0) + 40}}rpx; top:{{item.y || 0}}rpx; width:{{item.w || 80}}rpx; height:{{item.h || 72}}rpx;" bindtap="onNodeTap" data-id="{{item.id}}">
          <view class="node-inner" style="{{item.maskStyle || ''}}">
            <view class="icon-box" catchtap="onToggleCollapse" data-id="{{item.id}}">
               <view wx:if="{{item.iconType == 'plus'}}" class="circle-icon"><view class="line-h"></view><view class="line-v"></view></view>
               <view wx:if="{{item.iconType == 'minus'}}" class="circle-icon"><view class="line-h"></view></view>
               <view wx:if="{{item.iconType == 'leaf'}}" class="leaf-dot">·</view>
               <view wx:if="{{item.iconType == 'marriage'}}" class="spouse-icon">⚭</view>
            </view>
            <text class="p-name">{{item.name || '未命名'}}</text>
            <text class="p-life">{{item.life || ''}}</text>
          </view>
        </view>
      </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- Progenitor Dropdown Menu -->
  <view wx:if="{{showProgenitorDropdown}}" class="dropdown-overlay" bindtap="closeProgenitorDropdown">
    <view class="dropdown-content" catchtap="catchTap">
      <view class="dropdown-header">
        <text class="dropdown-title">世系列表</text>
      </view>
      <scroll-view class="dropdown-list" scroll-y>
        <!-- New Tree Option -->
        <view class="dropdown-item new-tree-item" catchtap="onNewTree" data-action="new-tree">
          <view class="progenitor-dropdown-row">
            <text class="progenitor-dropdown-name">＋ 新建家谱</text>
          </view>
        </view>

        <!-- Thick separator below new tree option -->
        <view class="workspace-separator"></view>

        <!-- Workspace Groups -->
        <block wx:for="{{progenitorWorkspaces}}" wx:for-item="workspace" wx:for-index="wsIndex" wx:key="id">
          <!-- Workspace separator (thick) between different workspaces -->
          <view wx:if="{{wsIndex > 0}}" class="workspace-separator"></view>

          <!-- Empty workspace -->
          <view wx:if="{{workspace.progenitors.length === 0}}" class="empty-workspace">
            <text>暂无始祖</text>
          </view>

          <!-- Progenitor List -->
          <view wx:for="{{workspace.progenitors}}" wx:for-item="item" wx:for-index="idx" wx:key="id" class="dropdown-item {{item._isLast ? 'last-in-workspace' : ''}}" catchtap="onSelectProgenitor" data-id="{{item.id}}" data-index="{{idx}}">
            <view class="progenitor-dropdown-row">
              <text class="progenitor-dropdown-name">{{item.name}}</text>
              <text wx:if="{{item.bYear}}" class="progenitor-dropdown-year-inline">生于 {{item.bYear}}年</text>
              <view class="progenitor-stats-icons">
                <text class="stat-icon male">♂ {{item.maleDescendants || 0}}</text>
                <text class="stat-icon female">♀ {{item.femaleDescendants || 0}}</text>
                <text class="stat-icon marriage">👰 {{item.marriageCount || 0}}</text>
              </view>
            </view>
          </view>
        </block>
      </scroll-view>
    </view>
  </view>



  <!-- ISOLATED COMPONENT -->
  <profile-editor
    show="{{showDrawer}}"
    person="{{_editingPerson}}"
    spouses="{{_displaySpouses}}"
    children="{{_displayChildren}}"
    father="{{_displayFather}}"
    motherRange="{{motherRange}}"
    currentMotherName="{{currentMotherName}}"
    pendingMotherSelected="{{_pendingMotherSelected}}"
    currentRootId="{{db.activeRootId || ''}}"
    showJumpBtn="{{showJumpBtn}}"
    canAddFather="{{canAddFather}}"
    creatingProfile="{{creatingProfile}}"
    hometownHint="{{_hometownHint}}"
    bind:close="onCloseDrawer"
    bind:closeprofile="onCloseDrawer"
    bind:commit="onCommit"
    bind:updatefield="onUpdateField"
    bind:motherchange="onMotherChange"
    bind:jump="onNodeTap"
    bind:jumptotree="onJumpToHisTree"
    bind:addspouse="onAddSpouse"
    bind:addchild="onAddChild"
    bind:addfather="onAddFather"
    bind:delete="onDelete"
  />

  <canvas type="2d" id="exportCanvas" style="position:fixed; left:9999px; width:{{maxR}}px; height:{{maxH}}px;"></canvas>
</view>