.container {
  padding: 30rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.btn-group {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.upload-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  padding: 24rpx;
}

.check-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: white;
  font-size: 28rpx;
  border-radius: 12rpx;
  border: none;
  padding: 24rpx;
}

.status-text, .url-text {
  display: block;
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  word-break: break-all;
  background: #f9f9f9;
  padding: 20rpx;
  border-radius: 8rpx;
}

.url-text {
  color: #2196F3;
  font-family: monospace;
  font-size: 20rpx;
}

.hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
  text-align: center;
}

.tips {
  background: #fff9c4;
  border-radius: 12rpx;
  padding: 24rpx;
  border-left: 6rpx solid #ffeb3b;
}

.tips-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #f57f17;
  margin-bottom: 16rpx;
}

.tips-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.8;
  margin-bottom: 8rpx;
}
