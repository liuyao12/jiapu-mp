<view class="container">
  <view class="header">
    <text class="title">上传楷体字体</text>
    <text class="subtitle">从本地选择楷体 .ttf 文件上传到云存储</text>
  </view>

  <view class="card">
    <view class="card-title">上传操作</view>
    <view class="btn-group">
      <button
        class="upload-btn"
        bindtap="uploadFontFile"
        disabled="{{uploading}}"
      >
        {{uploading ? '上传中...' : '选择并上传'}}
      </button>

      <button
        class="check-btn"
        bindtap="listFiles"
        disabled="{{uploading}}"
      >
        检查云存储文件
      </button>
    </view>
  </view>

  <view class="card" wx:if="{{status}}">
    <view class="card-title">状态</view>
    <text class="status-text selectable">{{status}}</text>
  </view>

  <view class="card" wx:if="{{fileUrl}}">
    <view class="card-title">下载地址</view>
    <text class="url-text selectable" selectable="true">{{fileUrl}}</text>
    <text class="hint">长按可复制，然后粘贴到 app.js 的 KAITI_FONT_URL</text>
  </view>

  <view class="tips">
    <view class="tips-title">使用步骤：</view>
    <view class="tips-item">1. 点击"选择并上传"，从 Windows 系统选择楷体文件</view>
    <view class="tips-item">2. 通常位置: C:\Windows\Fonts\simkai.ttf</view>
    <view class="tips-item">3. 上传成功后，复制下载地址到 app.js</view>
  </view>
</view>
