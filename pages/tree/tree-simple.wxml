<!-- tree-simple.wxml - 简化但功能完整的家谱树 -->
<view class="app-container">
  <!-- 顶部栏 -->
  <view class="topbar">
    <!-- 第1行：左侧导入，中间标题，右侧导出 -->
    <view class="bar-row title-row">
      <view class="title-left">
        <button class="tb-btn action-btn" size="mini" bindtap="onImport">📥 导入</button>
      </view>
      <view class="title-center">
        <text class="family-title">{{familyName}}</text>
      </view>
      <view class="title-right">
        <button class="tb-btn action-btn" size="mini" bindtap="onExport">💾 导出</button>
      </view>
    </view>

    <!-- 第2行：视图切换控件 -->
    <view class="bar-row toggle-row">
      <view class="toggle-left">
        <button class="tb-btn action-btn" size="mini" bindtap="onReset">🔄 清空</button>
      </view>
      <view class="toggle-center">
        <label class="toggle-item">
          <switch checked="{{showSpouses}}" bindchange="toggleSpouses" color="#0277bd" style="transform:scale(0.6);"/>
          <text class="toggle-text">配偶</text>
        </label>
        <label class="toggle-item">
          <switch checked="{{showMaternal}}" bindchange="toggleMaternal" color="#0277bd" style="transform:scale(0.6);"/>
          <text class="toggle-text">外甥</text>
        </label>
        <label class="toggle-item">
          <switch checked="{{showTimeline}}" bindchange="toggleTimeline" color="#0277bd" style="transform:scale(0.6);"/>
          <text class="toggle-text">时间轴</text>
        </label>
      </view>
      <view class="toggle-right">
        <!-- 预留空位 -->
      </view>
    </view>
  </view>

  <!-- 空树状态：显示添加始祖按钮 -->
  <view wx:if="{{!db.activeRootId || nodes.length === 0}}" class="empty-state">
    <view class="empty-icon">🌳</view>
    <text class="empty-tip">家谱空空如也</text>
    <text class="empty-sub">点击下方按钮，添加第一位始祖</text>
    <button class="add-ancestor-btn" bindtap="onAddAncestorBtnTap">＋ 添加始祖</button>
  </view>

  <!-- 主树区域 -->
  <view wx:else class="tree-area-outer">
    <scroll-view id="mainScroll" class="tree-area-body" scroll-x="{{true}}" scroll-y="{{true}}" scroll-left="{{0}}" scroll-top="{{0}}">
      <view class="canvas-wrapper">
        <!-- 标尺（时间轴视图：年份标尺；标准视图：代际块） -->
        <view class="ruler-container">
          <!-- 标准视图：代际块 -->
          <view wx:if="{{!showTimeline}}">
            <view wx:for="{{rulerTicks}}" wx:key="x" class="gen-block" style="left:{{item.x}}rpx; width:80rpx;">
              <text wx:if="{{item.label}}" class="gen-block-label">{{item.label}}</text>
            </view>
          </view>
          <!-- 时间轴视图：年份刻度 -->
          <view wx:if="{{showTimeline}}">
            <view wx:for="{{rulerTicks}}" wx:key="x" class="tick {{item.isCurrentYear?'current-year':''}}" style="left:{{(item.x || 0) + 40}}rpx">
              <text wx:if="{{item.label}}" class="tick-label">{{item.label}}</text>
            </view>
          </view>
          <!-- 2026年线（从标尺顶部开始，延伸到屏幕底部） -->
          <view wx:if="{{showTimeline && currentYearLineX >= 0}}" class="current-year-line" style="left:{{(currentYearLineX || 0) + 40}}rpx;"></view>
          <!-- 2026年标签 -->
          <text wx:if="{{showTimeline && currentYearLineX >= 0}}" class="current-year-label" style="left:{{(currentYearLineX || 0) + 94}}rpx;">{{currentYear || 2026}}年</text>
        </view>

        <!-- Canvas内容 -->
        <view class="canvas" style="width:{{maxR}}rpx; height:{{maxH}}rpx;">
          <view class="tree-content">
            <!-- 连接线 -->
            <view wx:for="{{lines}}" wx:key="index" class="line {{item.type || 'stem'}}" style="left:{{(item.x || 0) + 40}}rpx; top:{{item.y || 0}}rpx; width:{{item.w || 1.5}}rpx; height:{{item.h || 1.5}}rpx;"></view>
            <!-- 节点 -->
            <view wx:for="{{nodes}}" wx:key="id" class="node {{item.gender || 'unknown'}} {{item.isSpouse?'spouse':''}}" style="left:{{(item.x || 0) + 40}}rpx; top:{{item.y || 0}}rpx; width:{{item.w || 80}}rpx; height:{{item.h || 72}}rpx;" bindtap="onNodeTap" data-id="{{item.id}}">
              <view class="node-inner" style="{{item.maskStyle || ''}}">
                <view class="icon-box" catchtap="onToggleCollapse" data-id="{{item.id}}">
                  <view wx:if="{{item.iconType == 'plus'}}" class="circle-icon"><view class="line-h"></view><view class="line-v"></view></view>
                  <view wx:if="{{item.iconType == 'minus'}}" class="circle-icon"><view class="line-h"></view></view>
                  <view wx:if="{{item.iconType == 'leaf'}}" class="leaf-dot">·</view>
                  <view wx:if="{{item.iconType == 'marriage'}}" class="spouse-icon">⚭</view>
                </view>
                <text class="p-name">{{item.name || '未命名'}}</text>
                <text class="p-life">{{item.life || ''}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 人物编辑抽屉组件 -->
  <profile-editor
    show="{{showDrawer}}"
    editing-id="{{editingId}}"
    draft-person="{{draftPerson}}"
    display-spouses="{{_displaySpouses}}"
    display-children="{{_displayChildren}}"
    display-father="{{_displayFather}}"
    mother-range="{{motherRange}}"
    current-mother-name="{{currentMotherName}}"
    show-jump-btn="{{showJumpBtn}}"
    can-add-father="{{canAddFather}}"
    creating-profile="{{creatingProfile}}"
    hometown-hint="{{_hometownHint}}"
    bind:save="onSaveProfile"
    bind:close="onCloseDrawer"
    bind:addchild="onAddChild"
    bind:addfather="onAddFather"
    bind:addspouse="onAddSpouse"
    bind:delete="onDelete"
  />
</view>