/* Workspace separator - darker line between different workspaces (vs lighter #f0f0f0 within) */
.workspace-separator {
  width: 100%;
  margin: 4rpx 0;
  height: 1rpx;
  background: #ccc;
}

.workspace-swipe-shell {
  position: relative;
  overflow: hidden;
  background: #fff;
}

.workspace-delete-panel {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 1;
  width: 116rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #c62828;
}

.workspace-delete-action {
  width: 96rpx !important;
  height: 56rpx !important;
  line-height: 54rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  border: none !important;
  border-radius: 6rpx !important;
  background: transparent !important;
  color: #fff !important;
  font-size: 24rpx !important;
}

.workspace-delete-action::after {
  border: none !important;
}

.workspace-delete-rail {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  width: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #c62828;
  transition: opacity 0.18s ease;
}

.workspace-delete-rail-mark {
  margin-left: -18rpx;
  color: #c62828;
  font-size: 24rpx;
  line-height: 1;
}

.workspace-swipe-content {
  position: relative;
  z-index: 2;
  background: #fff;
  transform: translateX(0);
  transition: transform 0.18s ease;
  will-change: transform;
}

.workspace-swipe-shell.is-open .workspace-swipe-content {
  transform: translateX(-116rpx);
}

.workspace-swipe-shell.is-open .workspace-delete-rail {
  opacity: 0;
}

