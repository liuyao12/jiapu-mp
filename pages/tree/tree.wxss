/* Current year line - full height vertical line，从标尺顶部延伸到屏幕底部（不受maxH限制） */
/* 2026年线标签 - 标尺的一部分，在竖线右侧 */
.tree-content {
  position: relative;
  padding-top: 80rpx;
}

.timeline-event-band {
  position: absolute;
  top: 0;
  min-width: 2rpx;
  pointer-events: none;
  z-index: 1;
  box-sizing: border-box;
  overflow: visible;
}
.timeline-event-band.tone-0 { background: rgba(194, 137, 43, 0.24); }
.timeline-event-band.tone-1 { background: rgba(80, 137, 128, 0.22); }
.timeline-event-band.tone-2 { background: rgba(132, 111, 151, 0.22); }
.timeline-event-band.tone-imperial { background: rgba(255, 212, 0, 0.24); }
.timeline-event-band.tone-crown-prince { background: rgba(0, 141, 122, 0.22); }
.timeline-event-band.tone-empress { background: rgba(217, 144, 39, 0.22); }
.timeline-event-band.tone-noble-consort { background: rgba(243, 201, 120, 0.20); }
.timeline-event-band.current-year-event { background: transparent; z-index: 30; }
.timeline-event-edge {
  position: absolute;
  top: 0;
  bottom: 0;
  pointer-events: none;
  z-index: 1;
}
.timeline-event-edge.left { left: 0; }
.timeline-event-edge.right { right: 0; }
.timeline-event-band.tone-0 .timeline-event-edge { background: rgba(194, 137, 43, 0.24); }
.timeline-event-band.tone-1 .timeline-event-edge { background: rgba(80, 137, 128, 0.22); }
.timeline-event-band.tone-2 .timeline-event-edge { background: rgba(132, 111, 151, 0.22); }
.timeline-event-band.tone-imperial .timeline-event-edge { background: rgba(255, 212, 0, 0.42); }
.timeline-event-band.tone-crown-prince .timeline-event-edge { background: rgba(0, 141, 122, 0.38); }
.timeline-event-band.tone-empress .timeline-event-edge { background: rgba(217, 144, 39, 0.38); }
.timeline-event-band.tone-noble-consort .timeline-event-edge { background: rgba(243, 201, 120, 0.38); }
.timeline-event-band.current-year-event .timeline-event-edge { background: rgba(230, 81, 0, 0.9); z-index: 30; }
.timeline-event-band.tone-0 .timeline-event-label { color: #c2892b; }
.timeline-event-band.tone-1 .timeline-event-label { color: #508980; }
.timeline-event-band.tone-2 .timeline-event-label { color: #846f97; }
.timeline-event-band.tone-imperial .timeline-event-label { color: #d59a00; }
.timeline-event-band.tone-crown-prince .timeline-event-label { color: #00796b; }
.timeline-event-band.tone-empress .timeline-event-label { color: #b56f14; }
.timeline-event-band.tone-noble-consort .timeline-event-label { color: #a26e18; }
.timeline-event-band.current-year-event .timeline-event-label { color: #e65100; z-index: 40; }
.timeline-event-label {
  position: sticky;
  top: 72rpx;
  display: inline-block;
  margin-left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  line-height: 24rpx;
  color: #c2892b;
  font-family: "SimSun", "Songti SC", "STSong", serif;
  white-space: nowrap;
  background: transparent;
  padding: 0 2rpx;
  text-shadow:
    -1rpx -1rpx 0 rgba(255,255,255,0.9),
     1rpx -1rpx 0 rgba(255,255,255,0.9),
    -1rpx  1rpx 0 rgba(255,255,255,0.9),
     1rpx  1rpx 0 rgba(255,255,255,0.9),
     0 0 4rpx rgba(255,255,255,0.9);
  z-index: 2;
}

/* ── Nodes ── */
.node { position: absolute; top: 0; left: 0; display: flex; align-items: stretch; z-index: 10; box-sizing: border-box; overflow: visible; min-height: 0; padding: 0 !important; margin: 0 !important; }
.node-inner { position: relative; display: flex; align-items: center; background: #fff; border: 0 solid transparent; border-radius: 0; padding: 0 14rpx 0 0; width: 100%; height: 100%; box-sizing: border-box; line-height: 1.2; min-height: 0; overflow: visible; box-shadow: none; z-index: 2; }
.standard-node .node-inner { height: calc(100% + 1rpx); }
.timeline-node .node-inner { border-right-width: 0; }
.timeline-node-year-edge { position: absolute; z-index: 2; pointer-events: none; }
.timeline-node-inline-edge { position: absolute; top: 0; bottom: 0; z-index: 15; pointer-events: none; }
/* Node borders are drawn by these overlays, not by .node-inner.
   Keeping .node-inner borderless makes overlay edges sit on the true outer box, matching screenshot canvas rendering. */
.node-border-edge { position: absolute; pointer-events: none; z-index: 15; }
.node-border-edge.top { left: 0; right: 0; top: 0; height: 2rpx; }
.node-border-edge.bottom { left: 0; right: 0; bottom: 0; height: 2rpx; }
.node-border-edge.left { top: 0; bottom: 0; left: 0; width: 2rpx; }
.node-border-edge.right { top: 0; bottom: 0; right: 0; width: 2rpx; }
.node-seam { display: none; }
.male   .node-inner { background: #bbdefb !important; }
.female .node-inner { background: #fce4ec !important; }
.unknown .node-inner { background: #dcedc8 !important; }
.personal-event-mark { position: absolute; top: 2rpx; bottom: 2rpx; width: 2rpx; border-radius: 1rpx; background: rgba(95,168,211,0.78); z-index: 1; pointer-events: none; box-sizing: border-box; overflow: hidden; }
.personal-event-mark.underlay { background: #fff !important; border-radius: 0; z-index: 0; }
.personal-event-mark.tone-0 { background: rgba(95,168,211,0.78); }
.personal-event-mark.tone-1 { background: rgba(142,138,232,0.78); }
.personal-event-mark.tone-2 { background: rgba(227,138,111,0.78); }
.personal-event-mark.tone-imperial { background: rgba(255,212,0,0.78); }
.personal-event-mark.tone-crown-prince { background: rgba(42,215,195,0.78); }
.personal-event-mark.tone-empress { background: rgba(217,144,39,0.78); }
.personal-event-mark.tone-noble-consort { background: rgba(243,201,120,0.78); }
.personal-event-mark.range { background: rgba(185,216,236,0.72); border-radius: 2rpx; opacity: 1; }
.personal-event-mark.range.split-left-cap { border-top-left-radius: 0; border-bottom-left-radius: 0; }
.personal-event-mark.range.split-right-cap { border-top-right-radius: 0; border-bottom-right-radius: 0; }
.personal-event-mark.range.tone-0 { background: rgba(185,216,236,0.72); }
.personal-event-mark.range.tone-1 { background: rgba(208,202,250,0.72); }
.personal-event-mark.range.tone-2 { background: rgba(244,195,180,0.72); }
.personal-event-mark.range.tone-imperial { background: rgba(255,228,119,0.72); }
.personal-event-mark.range.tone-crown-prince { background: rgba(159,240,230,0.72); }
.personal-event-mark.range.tone-empress { background: rgba(244,197,111,0.72); }
.personal-event-mark.range.tone-noble-consort { background: rgba(249,223,173,0.72); }
.personal-event-cap { position: absolute; top: 0; bottom: 0; width: 2rpx; background: rgba(95,168,211,0.78); pointer-events: none; }
.personal-event-cap.left { left: 0; }
