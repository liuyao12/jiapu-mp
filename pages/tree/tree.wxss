/* pages/tree/tree.wxss */
.app-container { height: 100vh; display: flex; flex-direction: column; background: #f0f2f5; font-family: "SimSun", serif; overflow: hidden; }
text, view, button, input { font-weight: normal !important; }

/* ── Topbar ── */
.topbar { background: #fff; border-bottom: 1rpx solid #ddd; z-index: 200; flex-shrink: 0; padding: 12rpx 16rpx 8rpx; }

/* Shared row */
.bar-row { display: flex; align-items: center; }

/* Row 1: title */
.title-row { justify-content: space-between; margin-bottom: 4rpx; }
.title-left { display: flex; align-items: center; min-width: 120rpx; }
.title-center { display: flex; align-items: center; justify-content: center; flex: 1; min-width: 0; }
.title-right { display: flex; gap: 8rpx; align-items: center; min-width: 120rpx; justify-content: flex-end; }
.family-title { font-size: 28rpx; color: #333; font-weight: 500; max-width: 100%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.stats { font-size: 16rpx; color: #999; }
.action-btn { background: #fff !important; color: #666 !important; font-size: 20rpx !important; padding: 0 16rpx !important; height: 48rpx; line-height: 48rpx; border: none !important; }
.backup-btn { padding: 0 12rpx !important; }
.screenshot-btn { min-width: 48rpx; width: 48rpx; padding: 0 !important; font-size: 24rpx !important; line-height: 48rpx !important; text-align: center; display: flex !important; align-items: center; justify-content: center; }
.screenshot-icon {
  position: relative;
  display: block;
  width: 42rpx;
  height: 34rpx;
  box-sizing: border-box;
}
.screenshot-image {
  width: 42rpx;
  height: 34rpx;
  display: block;
}
.event-btn { min-width: 56rpx; padding: 0 8rpx !important; }
.timeline-event-btn { min-width: 96rpx; padding: 0 10rpx !important; margin-left: 12rpx !important; flex-shrink: 0; border: 1rpx solid #c9cfd6 !important; border-radius: 6rpx !important; white-space: nowrap; }
.timeline-event-btn.is-disabled,
.timeline-event-btn[disabled] {
  color: #b8bec5 !important;
  border-color: #e1e4e8 !important;
  background: #fff !important;
  opacity: 1;
}
.event-menu-text { white-space: nowrap; line-height: 48rpx; color: #666; }
.timeline-event-btn.is-disabled .event-menu-text,
.timeline-event-btn[disabled] .event-menu-text {
  color: #b8bec5 !important;
}

.back-btn { background: #fff3e0 !important; color: #e65100 !important; font-size: 20rpx !important; padding: 0 16rpx !important; height: 48rpx; line-height: 48rpx; }
.new-btn { background: #e3f2fd !important; color: #0277bd !important; font-size: 20rpx !important; padding: 0 16rpx !important; height: 48rpx; line-height: 48rpx; }
.btn-spacer { flex: 1; }
.btn-group { display: flex; gap: 8rpx; align-items: center; }

/* Row 2: toggles */
.toggle-row { gap: 12rpx; justify-content: flex-start; padding-left: 0; }
.toggle-left { display: flex; align-items: center; min-width: 96rpx; flex: 0 0 auto; }
.toggle-center { display: flex; align-items: center; gap: 22rpx; flex: 1; justify-content: space-between; min-width: 0; }
.toggle-right { display: flex; align-items: center; min-width: 0; width: 0; justify-content: flex-end; }
.toggle-label { font-size: 20rpx; color: #999; margin-right: 4rpx; }
.toggle-item { display: flex; align-items: center; margin-right: 0; flex-shrink: 0; }
.toggle-item.first-toggle { margin-left: 20rpx; }
.toggle-switch-slot { width: 70rpx; height: 48rpx; display: flex; align-items: center; justify-content: flex-start; overflow: visible; flex-shrink: 0; }
.toggle-switch { transform: scale(0.52); transform-origin: left center; }
.toggle-text  { font-size: 20rpx; color: #555; margin-left: 8rpx; white-space: nowrap; }
.toggle-spacer { flex: 1; }

/* Row 2: action buttons */
.btn-row { gap: 12rpx; margin-bottom: 6rpx; }
.tb-btn { margin: 0 !important; padding: 0 12rpx !important; height: 48rpx; line-height: 48rpx; font-size: 20rpx; border-radius: 6rpx !important; display: flex; align-items: center; justify-content: center; }
.import-btn, .export-btn { width: 100rpx; background: #e3f2fd !important; color: #0277bd !important; }
.export-btn { background: #e8f5e9 !important; color: #2e7d32 !important; }
.reset-btn { background: #f0f0f0 !important; color: #333 !important; padding: 0 8rpx !important; font-size: 20rpx; }

/* Toggles */
.toggle-label { font-size: 20rpx; color: #999; margin-right: 4rpx; }
.toggle-item { display: flex; align-items: center; margin-right: 0; flex-shrink: 0; }
.toggle-text  { font-size: 20rpx; color: #555; margin-left: 8rpx; white-space: nowrap; }

/* ── Empty state ── */
/* ── Empty state ── */
.empty-state {
  flex: 1;
  height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}
.empty-icon { font-size: 100rpx; margin-bottom: 20rpx; }
.empty-tip { font-size: 34rpx; color: #333; font-weight: bold; margin-bottom: 12rpx; }
.empty-sub { font-size: 26rpx; color: #888; margin-bottom: 48rpx; }
.add-ancestor-btn {
  background: #1565c0 !important;
  color: #fff !important;
  font-size: 32rpx !important;
  padding: 0 60rpx !important;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx !important;
  border: none !important;
  box-shadow: 0 6rpx 24rpx rgba(21,101,192,0.35);
}

/* ── Tree area ── */
.tree-area-outer {
  flex: 1;
  height: 0;
  background: #fff;
  position: relative;
  width: 100%;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

.tree-area-body {
  flex: 1;
  height: 0;
  width: 100%;
  overflow: auto;
  position: relative;
  min-height: 200rpx;
}

.canvas-wrapper {
  width: 100%;
  min-height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
  position: relative;
}

/* 标尺容器 - 使用 sticky 定位固定在 canvas 顶部 */
.ruler-container {
  position: sticky;
  top: 0;
  height: 64rpx;
  width: 100%;
  border-bottom: 0;
  background: #fff;
  z-index: 150;
  flex-shrink: 0;
  overflow: visible;
}

/* Opaque background covering entire horizontal scroll range */
.ruler-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: -9999rpx;
  right: -9999rpx;
  bottom: 0;
  background: #fff;
  z-index: -1;
}

/* 标尺底部的水平线（贯穿整个标尺长度） */
.ruler-container::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: -9999rpx;
  right: -9999rpx;
  height: 3rpx;
  background: #7c858e;
  z-index: 1;
}

.canvas {
  flex-shrink: 0;
  margin-left: 0;
  position: relative;
  min-height: 100rpx;
}

/* 标尺刻度线样式 */
.tick {
  position: absolute;
  bottom: 3rpx; /* 在标尺底部水平线之上 */
  height: 8rpx; /* 短刻度线 */
  width: 1rpx;
  background: #545e68;
  z-index: 10;
  transform: translateX(-50%);
}

/* 中等刻度（每20年） */
.tick.type-medium {
  height: 12rpx;
  width: 2rpx;
}

/* 大刻度（每100年） */
.tick.type-major {
  height: 24rpx; /* 更高的刻度 */
  width: 4rpx; /* 更粗的刻度 */
  background: #242a31;
}

/* 当前年刻度 */
.tick.current-year {
  height: 20rpx;
  width: 2rpx;
  background: #e65100;
}

.tick-label {
  position: absolute;
  bottom: 14rpx; /* 标签在刻度线上方，考虑水平线高度 */
  left: 50%;
  transform: translateX(-50%);
  font-size: 24rpx;
  color: #000;
  font-family: Consolas;
  white-space: nowrap;
  z-index: 10;
}

.tick.current-year .tick-label {
  color: #e65100;
  font-weight: bold;
}

/* 标准视图：代际块 */
.gen-block {
  position: absolute;
  top: 0;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  border-left: 0;
  z-index: 5;
}
.gen-block::before,
.gen-block.last::after {
  content: '';
  position: absolute;
  top: 0;
  width: 2rpx;
  height: 64rpx;
  background: #8f969e;
}
.gen-block::before {
  left: 0;
}
.gen-block.last::after {
  right: 0;
}

.screenshot-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 1px;
  height: 1px;
  pointer-events: none;
}
